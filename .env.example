# RxFlow environment variables
# Copy this to .env and update the values for your environment.

# Local Postgres or AWS RDS connection string
DATABASE_URL=postgresql+asyncpg://rxflow:rxflow@localhost:5432/rxflow

# Anthropic API key for AI anomaly detection
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key

# Allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
